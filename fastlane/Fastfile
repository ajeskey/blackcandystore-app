default_platform(:ios)

# Absolute path to the Xcode project (fastlane runs from the repo root).
XCODE_PROJECT = "iosApp/iosApp.xcodeproj".freeze
XCODE_SCHEME = "iosApp".freeze

ANDROID_AAB = "androidApp/build/outputs/bundle/release/androidApp-release.aab".freeze

platform :android do
  desc "Build a signed AAB and upload it to the Google Play internal (dev) testing track"
  desc "Requires (see .env.example):"
  desc "  ANDROID_KEYSTORE_PATH, ANDROID_KEYSTORE_PASSWORD, ANDROID_KEY_ALIAS, ANDROID_KEY_PASSWORD"
  desc "  and a Play service account key via GOOGLE_PLAY_JSON_KEY (path) or GOOGLE_PLAY_JSON_KEY_DATA (contents)."
  lane :internal do
    gradle(
      task: "clean bundleRelease",
      project_dir: ".",
      properties: {
        "android.injected.signing.store.file" => ENV.fetch("ANDROID_KEYSTORE_PATH"),
        "android.injected.signing.store.password" => ENV.fetch("ANDROID_KEYSTORE_PASSWORD"),
        "android.injected.signing.key.alias" => ENV.fetch("ANDROID_KEY_ALIAS"),
        "android.injected.signing.key.password" => ENV.fetch("ANDROID_KEY_PASSWORD"),
      },
    )

    upload_to_play_store(
      track: "internal",
      aab: ANDROID_AAB,
      json_key: ENV["GOOGLE_PLAY_JSON_KEY"],
      json_key_data: ENV["GOOGLE_PLAY_JSON_KEY_DATA"],
      release_status: "draft",
      skip_upload_apk: true,
      skip_upload_metadata: true,
      skip_upload_images: true,
      skip_upload_screenshots: true,
    )
  end
end

platform :ios do
  desc "Frame iOS screenshots with device frames and titles"
  lane :frame do
    frameit(
      path: "./fastlane/screenshots/ios"
    )
  end

  desc "Build the iOS app and upload it to TestFlight"
  desc "Auth uses an App Store Connect API key. Provide these env vars (see .env.example):"
  desc "  ASC_KEY_ID, ASC_ISSUER_ID, and either ASC_KEY_CONTENT (base64 or raw .p8) or ASC_KEY_FILEPATH."
  desc "Optionally set BUILD_NUMBER to override the build number (defaults to the project value)."
  lane :beta do
    api_key = app_store_connect_api_key(
      key_id: ENV.fetch("ASC_KEY_ID"),
      issuer_id: ENV.fetch("ASC_ISSUER_ID"),
      key_content: ENV["ASC_KEY_CONTENT"],
      key_filepath: ENV["ASC_KEY_FILEPATH"],
      is_key_content_base64: ENV["ASC_KEY_CONTENT_BASE64"] == "true",
      in_house: false
    )

    # Optionally bump the build number for this upload (TestFlight rejects duplicates).
    if ENV["BUILD_NUMBER"]
      increment_build_number(
        xcodeproj: XCODE_PROJECT,
        build_number: ENV["BUILD_NUMBER"]
      )
    end

    build_app(
      project: XCODE_PROJECT,
      scheme: XCODE_SCHEME,
      configuration: "Release",
      export_method: "app-store",
      # Let Xcode manage automatic signing and create/update the provisioning profile,
      # authorized by the App Store Connect API key above (CODE_SIGN_STYLE = Automatic).
      xcargs: "-allowProvisioningUpdates",
      output_directory: "build/ios",
      clean: true
    )

    upload_to_testflight(
      api_key: api_key,
      # Uploading only; distribution to testers is managed in App Store Connect / TestFlight.
      skip_waiting_for_build_processing: true,
      skip_submission: true
    )
  end
end
