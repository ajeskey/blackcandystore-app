# App identifier for the iOS app. Kept in sync with iosApp/.../Configuration/Config.xcconfig
# (BUNDLE_ID) and the App Store Connect record.
for_platform :ios do
  # App Store Connect auth is provided at runtime via an API key (see the `beta` lane
  # in the Fastfile and .env.example). No Apple ID / password needed.
  app_identifier(ENV["BUNDLE_ID"] || "io.blackcandystore.app")
end

for_platform :android do
  # Google Play package name; auth via a service account key (see the `internal` lane).
  package_name(ENV["ANDROID_PACKAGE_NAME"] || "io.blackcandystore.app")
end
