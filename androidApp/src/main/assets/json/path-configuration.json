{
  "settings": {
    "screenshots_enabled": true
  },
  "rules": [
    {
      "patterns": [
        ".*"
      ],
      "properties": {
        "context": "default",
        "uri": "hotwire://fragment/web",
        "pull_to_refresh_enabled": true
      }
    },
    {
      "patterns": [
        "^$",
        "^/$"
      ],
      "properties": {
        "uri": "hotwire://fragment/web/home",
        "presentation": "replace_root"
      }
    },
    {
      "patterns": [
        "^/library$"
      ],
      "properties": {
        "uri": "hotwire://fragment/web/library",
        "presentation": "replace_root"
      }
    },
    {
      "patterns": [
        "^/dialog/*"
      ],
      "properties": {
        "context": "modal",
        "uri": "hotwire://fragment/web/bottom_sheet",
        "pull_to_refresh_enabled": false
      }
    },
    {
      "patterns": [
        "^/libraries$"
      ],
      "properties": {
        "context": "default",
        "uri": "hotwire://fragment/web",
        "pull_to_refresh_enabled": true,
        "comment": "Library management screen (R5.1/5.2): full-screen list, standard push."
      }
    },
    {
      "patterns": [
        "^/libraries/active$",
        "^/libraries/active/.*"
      ],
      "properties": {
        "context": "modal",
        "uri": "hotwire://fragment/web",
        "pull_to_refresh_enabled": false,
        "comment": "Active-library selection (R5.1/5.2): transient picker, presented modally."
      }
    },
    {
      "patterns": [
        "^/library_invitations/new$",
        "^/library_invitations/[^/]+$"
      ],
      "properties": {
        "context": "modal",
        "uri": "hotwire://fragment/web",
        "pull_to_refresh_enabled": false,
        "comment": "Invite generation and invite redemption (R5.1/5.2): transient forms, modal."
      }
    },
    {
      "patterns": [
        "^/libraries/[^/]+/accesses$",
        "^/library_accesses$"
      ],
      "properties": {
        "context": "default",
        "uri": "hotwire://fragment/web",
        "pull_to_refresh_enabled": true,
        "comment": "Access list (R5.1/5.2): management list, standard push."
      }
    },
    {
      "patterns": [
        "^/settings/source_preference$",
        "^/source_preference$"
      ],
      "properties": {
        "context": "default",
        "uri": "hotwire://fragment/web",
        "pull_to_refresh_enabled": true,
        "comment": "Source-preference setting (R5.1/5.2): settings screen, standard push."
      }
    }
  ]
}
