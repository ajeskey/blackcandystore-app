# App Store Connect API key used by the Fastlane `beta` lane to build + upload to TestFlight.
# Create a key at App Store Connect ▸ Users and Access ▸ Integrations ▸ App Store Connect API.
# Copy this file to `.env` (gitignored) and fill in real values, OR set these as CI secrets.

# The bundle identifier (must match Config.xcconfig BUNDLE_ID and the App Store Connect app).
BUNDLE_ID=io.blackcandystore.app

# API key identifiers from App Store Connect.
ASC_KEY_ID=XXXXXXXXXX
ASC_ISSUER_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# Provide the .p8 private key ONE of two ways:
# 1) Inline contents (recommended for CI). Set ASC_KEY_CONTENT_BASE64=true if you base64-encode it.
ASC_KEY_CONTENT=
ASC_KEY_CONTENT_BASE64=false
# 2) OR a path to the .p8 file on disk (recommended for local use). Leave ASC_KEY_CONTENT blank.
#ASC_KEY_FILEPATH=./AuthKey_XXXXXXXXXX.p8

# Optional: override the build number for the next upload (TestFlight rejects duplicates).
#BUILD_NUMBER=11


# ------------------------------------------------------------------------------
# Google Play (Android) — used by the Fastlane `android internal` lane.
# ------------------------------------------------------------------------------
ANDROID_PACKAGE_NAME=io.blackcandystore.app

# Upload keystore used to sign the AAB (your upload key; Play App Signing re-signs).
ANDROID_KEYSTORE_PATH=./release.keystore
ANDROID_KEYSTORE_PASSWORD=
ANDROID_KEY_ALIAS=
ANDROID_KEY_PASSWORD=

# Google Play Developer API service account key (JSON). Create it in Google Cloud /
# Play Console (Setup > API access) with the "Release manager" permission.
# Provide ONE of the following:
#GOOGLE_PLAY_JSON_KEY=./play-service-account.json
#GOOGLE_PLAY_JSON_KEY_DATA=
